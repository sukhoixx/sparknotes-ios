{
  "expo": {
    "name": "SparkNotes",
    "slug": "sparknotes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "sparknotes",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sparknotes.app",
      "usesAppleSignIn": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.228391293170-82itthm8uao5q6g2nkvd856rfj570qub"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
