{
  "expo": {
    "name": "NewsBlock",
    "slug": "newsblock",
    "version": "2.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "newsblock",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.newsblock.app",
      "buildNumber": "11",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:sparknotes-production.up.railway.app"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ff2442",
          "sounds": []
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.228391293170-82itthm8uao5q6g2nkvd856rfj570qub"
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-2618352557321545~1264241124",
          "androidAppId": "ca-app-pub-3940256099942544~3347511713"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.newsblock.app",
      "versionCode": 22
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7a1b7bfc-3762-4976-bb82-9b805b346e66"
      }
    },
    "owner": "sukhoixx"
  }
}
