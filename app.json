{
  "expo": {
    "name": "NewsBlock",
    "slug": "newsblock",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "newsblock",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.newsblock.app",
      "buildNumber": "4",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:sparknotes-production.up.railway.app"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.228391293170-82itthm8uao5q6g2nkvd856rfj570qub"
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-2618352557321545~1264241124"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.newsblock.app"
    }
  }
}
